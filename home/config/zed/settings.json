{
  "status_bar": {
    "active_language_button": false
  },
  "prettier": {
    "allowed": true,
  },
  "inline_code_actions": false,
  "tasks": {
    "enabled": false,
  },
  "use_autoclose": false,
  "indent_guides": {
    "enabled": false,
    "coloring": "fixed",
    "background_coloring": "disabled",
  },
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "expand_excerpt_lines": 10,
  "excerpt_context_lines": 10,
  "which_key": {
    "enabled": true,
  },
  "text_rendering_mode": "subpixel",
  "icon_theme": "Colored Zed Icons Theme Dark",
  "session": {
    "trust_all_worktrees": true,
  },
  "sticky_scroll": {
    "enabled": true,
  },
  "vertical_scroll_margin": 12.0,
  "terminal": {
    "scroll_multiplier": 1.0,
    "alternate_scroll": "on",
    "scrollbar": {
      "show": "never",
    },
  },
  "proxy": "",
  "project_panel": {
    "dock": "right",
  },
  "outline_panel": {
    "button": false,
    "dock": "right",
  },
  "git_panel": {
    "dock": "right",
  },
  "agent": {
    "single_file_review": true,
    "enable_feedback": false,
    "dock": "left",
    "tool_permissions": {
      "default": "allow",
      "tools": {
        "create_directory": {
          "always_allow": [
            {
              "pattern": "^/home/tor/code/work/nuvola/nuvola-mobile-app/src/features/notifications/hooks/",
            },
          ],
        },
        "move_path": {
          "default": "allow",
        },
        "delete_path": {
          "always_allow": [
            {
              "pattern": "^nuvola-gateway-api/internal/notification/",
            },
            {
              "pattern": "^nuvola-mobile-app/src/features/notifications/hooks/",
            },
            {
              "pattern": "^nuvola-mobile-app/src/features/notifications/models/",
            },
            {
              "pattern": "^nuvola-mobile-app/src/features/notifications/",
            },
          ],
        },
        "open": {
          "default": "allow",
        },
        "terminal": {
          "default": "allow",
        },
        "fetch": {
          "default": "allow",
        },
      },
    },
    "default_model": {
      "effort": "high",
      "provider": "copilot_chat",
      "model": "gpt-5.5",
      "enable_thinking": true,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "cli_default_open_behavior": "new_window",
  "theme": "Gruvbox Dark Hard",
  "buffer_font_family": "Monaspace Neon",
  "title_bar": {
    "show_branch_name": false,
    "show_project_items": false,
    "show_onboarding_banner": false,
    "show_user_picture": false,
    "show_sign_in": false,
    "show_menus": false,
  },
  "toolbar": {
    "breadcrumbs": false,
    "agent_review": true,
    "code_actions": false,
    "quick_actions": false,
    "selections_menu": false,
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "show_edit_predictions": false,
  "collaboration_panel": {
    "dock": "right",
    "button": false,
  },
  "debugger": {
    "button": false,
  },
  "search": {
    "button": false,
  },
  "gutter": {
    "line_numbers": true,
    "runnables": false,
    "breakpoints": false,
    "folds": false,
    "min_line_number_digits": 3,
  },
  "scrollbar": {
    "diagnostics": "none",
    "cursors": false,
    "git_diff": true,
    "show": "auto",
  },
  "helix_mode": true,
  "relative_line_numbers": "enabled",
  "cursor_shape": "block",
  "cursor_blink": false,
  "current_line_highlight": "gutter",
  "auto_install_extensions": {
    "basher": true,
    "dockerfile": true,
    "nix": true,
    "ruff": true,
    "toml": true,
    "just-language-server": true,
    "justfile": true,
  },
  "load_direnv": "shell_hook",
  "auto_update": false,
  "git": {
    "blame": {
      "show_avatar": false,
    },
    "inline_blame": {
      "enabled": false,
    },
  },
  "inlay_hints": {
    "enabled": true,
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "rust": {
          "analyzerTargetDir": true,
        },
        "diagnostics": {
          "experimental": {
            "enable": true,
          },
        },
        "cargo": {
          "allTargets": false,
        },
        "check": {
          "workspace": false,
        },
      },
    },
    "tinymist": {
      "initialization_options": {
        "preview": {
          "background": {
            "enabled": true,
          },
        },
      },
      "settings": {
        "exportPdf": "onSave",
        "outputPath": "$root/$name",
        "formatterMode": "typstyle",
      },
    },
  },
  "languages": {
    "Typst": {
      "soft_wrap": "none",
    },
  },
  "edit_predictions": { "provider": "none" },
}
